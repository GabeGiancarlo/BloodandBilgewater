# === Blood and Bilgewater — Bevy-first .gitignore ===

# --- Rust / Bevy ---
/target/
**/*.rs.bk
*.pdb

# --- Unity generated folders (archived prototype only; no active Unity) ---
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# --- Unity generated project files ---
*.csproj
*.sln
*.slnx
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# --- IDE ---
.vs/
.idea/
.vscode/
.cursor/

# --- Local lab dev artifacts ---
dev_saves/

# --- Runtime-generated caches (rebuilt on first island-gen lab run) ---
assets/runtime/generated/
*.swp
*.swo

# --- OS / editor junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Environment ---
.env
.env.local

# --- Local-only large archive (kept out of history) ---
/Archive/DuplicateUnityProject_BloodandBildgewater/

# --- Quarantine for unneeded/junk files (local-only, never committed) ---
/trashcan/

# NOTE: Art and data are intentionally NOT ignored.
# Do not add global ignores for: *.aseprite, *.ase, *.png, *.json, *.ron,
# *.ttf, *.otf, *.wav, *.ogg, *.mp3, or asset manifests.
