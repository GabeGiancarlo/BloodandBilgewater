# === Blood and Bilgewater root .gitattributes ===
# Binary art/audio/font files are marked `binary` (no LFS).
# Git LFS is intentionally NOT used here for the migrated art (see
# docs/migration/bevy_restoration_audit.md "Git LFS status").

# Aseprite / source art
*.ase      binary
*.aseprite binary

# Raster art and references
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.psd  binary

# Fonts
*.ttf binary
*.otf binary

# Audio
*.wav binary
*.ogg binary
*.mp3 binary

# Text normalization
*.rs   text eol=lf
*.toml text eol=lf
*.ron  text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Unity reference files (archived) keep LF
*.cs   text eol=lf
*.meta text eol=lf
